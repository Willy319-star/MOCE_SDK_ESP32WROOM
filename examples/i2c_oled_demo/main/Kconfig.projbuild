menu "I2C OLED Demo"

choice OLED_DEMO_PROFILE
    prompt "OLED profile"
    default OLED_DEMO_PROFILE_096
    help
        Select the OLED module profile used by this demo.

config OLED_DEMO_PROFILE_096
    bool "0.96 inch SSD1306 128x64"

config OLED_DEMO_PROFILE_13
    bool "1.3 inch SH1106 128x64"

endchoice

endmenu
